# ============================================================
# Novel-to-Script Pro — 环境变量配置模板
# 复制此文件为 .env 并填入实际值
#   cp .env.example .env
# ============================================================

# ── 主 LLM API ──
LLM_API_KEY=sk-YOUR-API-KEY
LLM_BASE_URL=https://api.deepseek.com/v1
LLM_MODEL=deepseek-chat

# ── 备用 LLM API（轻量任务）──
LLM_LIGHT_API_KEY=sk-YOUR-API-KEY
LLM_LIGHT_BASE_URL=https://api.deepseek.com/v1
LLM_LIGHT_MODEL=deepseek-chat

# ── 图片生成 API（Nano Banana / 其他 OpenAI-compatible）──
IMAGE_GEN_API_KEY=
IMAGE_GEN_BASE_URL=
IMAGE_GEN_MODEL=gemini-3.1-flash-image-preview

# ── 图片反推 API ──
IMAGE_REVERSE_API_KEY=
IMAGE_REVERSE_BASE_URL=
IMAGE_REVERSE_MODEL=gemini-3.1-pro-preview

# ── SkyReels 视频生成 ──
SKYREELS_API_KEY=
SKYREELS_BASE_URL=
SKYREELS_SUBMIT_URL=
SKYREELS_TASK_URL=

# ── 文件上传服务（可选，用于图片上传后获取公网URL）──
TMPFILES_UPLOAD_URL=
CATBOX_UPLOAD_URL=

# ── 项目级配置 ──
PROJECT_OUTPUT_DIR=./output
PROJECT_LANGUAGE=zh-CN
